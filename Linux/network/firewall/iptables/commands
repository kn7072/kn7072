┌──────────────┬──────────────────────┬─────────────────────────────────────────────┐
│ ДЕЙСТВИЕ (-j)│ ГДЕ ДОПУСТИМО        │ НАЗНАЧЕНИЕ / ПРИМЕЧАНИЕ                     │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ ВЕРДИКТЫ (УПРАВЛЕНИЕ ПОТОКОМ)                                                     │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ ACCEPT       │ Все таблицы/цепочки  │ Пропустить пакет дальше по стеку            │
│ DROP         │ Все таблицы/цепочки  │ Тихо уничтожить пакет (обработка ─)         │
│ RETURN       │ Все таблицы/цепочки  │ Вернуться в родительскую цепочку            │
│ REJECT       │ filter (INPUT/FWD)   │ Отбросить + отправить ICMP/TCP RST ответ    │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ NAT (ТРАНСЛЯЦИЯ АДРЕСОВ)                                                          │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ DNAT         │ nat (PREROUTING, OUT)│ Изменить адрес/порт назначения (до роутинга)│
│ REDIRECT     │ nat (PREROUTING, OUT)│ Перенаправить на локальный порт/IP          │
│ SNAT         │ nat (POSTROUTING)    │ Изменить IP источника (статический)         │
│ MASQUERADE   │ nat (POSTROUTING)    │ Изменить IP источника (динамический, DHCP)  │
│ NETMAP       │ nat (все хуки)       │ Побайтовое отображение одной подсети на др. │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ МОДИФИКАЦИЯ ЗАГОЛОВКОВ                                                            │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ MARK         │ mangle               │ Установить fwmark для маршрутизации/QoS     │
│ CONNMARK     │ mangle, nat, filter  │ Сохранить/восстановить маркер соединения    │
│ TOS / DSCP   │ mangle               │ Изменить поле Quality of Service            │
│ TTL          │ mangle               │ Изменить Time-To-Live                       │
│ ECN          │ mangle               │ Изменить явное уведомление о перегрузке     │
│ CLASSIFY     │ mangle               │ Установить класс для tc (traffic shaping)   │
│ SECMARK      │ mangle, security     │ Назначить SELinux/AppArmor контекст пакету  │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ ЛОГИРОВАНИЕ И USERSPACE                                                           │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ LOG          │ Все таблицы          │ Запись в kern.log/dmesg (пакет идёт дальше) │
│ TRACE        │ Все таблицы          │ Отладка: лог каждого шага (требует nf_log)  │
│ NFLOG        │ Все таблицы          │ Передать метаданные демону (ulogd2, Wireshark)│
│ NFQUEUE      │ Все таблицы          │ Передать пакет целиком в userspace-демон    │
│ ULOG         │ filter, mangle       │ Legacy-аналог NFLOG (через multicast)       │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ СПЕЦИАЛЬНЫЕ И СЛУЖЕБНЫЕ                                                           │
├──────────────┼──────────────────────┼─────────────────────────────────────────────┤
│ CT           │ raw                  │ Управление conntrack (--notrack, --zone)    │
│ SYNPROXY     │ raw, mangle, filter  │ Защита от SYN-flood (проксирует TCP handshake)│
│ ИМЯ_ЦЕПОЧКИ  │ filter, nat, mangle  │ Прыжок в пользовательскую цепочку (-j MY_CH)│
